<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.attriax.attriax_android">
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Required by the Google Play Install Referrer client. -->
    <uses-permission android:name="com.android.vending.INSTALL_REFERRER" />
    <!--
        AD_ID is a normal-protection permission introduced in Android 13.
        It is granted at install time and is required for the SDK's
        dependency-free GAID lookup (AdvertisingIdProvider) to return a
        real advertising id on Android 13+. Apps built against API 32 or
        below do not need this permission.
    -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />
    <meta-data android:name="flutter_deeplinking_enabled" android:value="false" />
</manifest>
